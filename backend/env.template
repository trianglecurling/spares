# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_PATH=./data/spares.sqlite

# Time zone (used for league schedule + same-day checks)
# Example: America/New_York
TIME_ZONE=

# JWT Secret (generate a long random string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Azure Communication Services (for sending emails)
# Leave empty to log emails to console during development
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_COMMUNICATION_SENDER_EMAIL=noreply@tccnc.club

# Optional SMTP (e.g. Mailpit: SMTP 1025, web UI 8025). When SMTP_HOST is set, it is used
# instead of Azure. Typical local: SMTP_HOST=127.0.0.1, SMTP_PORT=1025, leave the rest default.
# SMTP_HOST=
# SMTP_FROM=
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# When server "test mode" is enabled (admin config), email is sent via SMTP to Mailpit
# (or another sink). Defaults: 127.0.0.1:1025
# TEST_MAILER_SMTP_HOST=127.0.0.1
# TEST_MAILER_SMTP_PORT=1025

# Twilio (for sending SMS)
# Leave empty to log SMS to console during development
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payments
# Comma-separated list of enabled providers: stripe, square, paypal
PAYMENT_ENABLED_PROVIDERS=stripe
PAYMENT_DEFAULT_PROVIDER=stripe
# Public base URL of this API (no trailing slash). Required for Square webhook signature verification.
# Example: https://api.example.com
# PAYMENT_WEBHOOK_BASE_URL=

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Square
# Use sandbox for testing; set to production for live payments
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SECRET=

# PayPal (stub adapter only; hosted checkout not implemented yet)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_SECRET=
# Test-only: intentionally delay webhook handling to validate UI waiting states
PAYMENT_WEBHOOK_TEST_DELAY_MS=0
# Payment reconciliation safety net (for missed/late webhooks)
PAYMENT_RECONCILE_ENABLED=true
PAYMENT_RECONCILE_INTERVAL_MS=60000
PAYMENT_RECONCILE_STALE_AFTER_SECONDS=120
PAYMENT_RECONCILE_BATCH_SIZE=25
# 0 = no max age. If >0, auto-reconciler skips pending orders older than this.
PAYMENT_RECONCILE_MAX_PENDING_AGE_SECONDS=0


# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=spares-backend
OTEL_EXPORTER_OTLP_ENDPOINT=https://observability.tccnc.club:4431
# OTEL_CAPTURE_CONSOLE_LOGS=true
# Optional overrides
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://observability.tccnc.club:4431/v1/logs
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
