{
  "name": "triangle-curling-spares",
  "version": "1.0.0",
  "description": "Member and club management for Triangle Curling Club",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "prosemirror-view": "1.41.8"
  },
  "scripts": {
    "dev": "bunx concurrently -n mailpit,apps -c magenta,auto \"bun run dev:mailpit\" \"bun run --elide-lines=0 --filter '*' dev\"",
    "dev:mailpit": "mailpit",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:backend": "bun run --filter backend dev",
    "dev:preview": "DB_CONFIG_PROFILE=preview bun run dev",
    "dev:backend:preview": "DB_CONFIG_PROFILE=preview bun run dev:backend",
    "db:migrate": "bun run --filter backend db:migrate",
    "db:migrate:preview": "DB_CONFIG_PROFILE=preview bun run db:migrate",
    "build": "bun run --filter frontend build && bun run --filter backend build",
    "build:frontend": "bun run --filter frontend build",
    "build:backend": "bun run --filter backend build",
    "storybook": "bun run --filter frontend storybook",
    "build-storybook": "bun run --filter frontend build-storybook",
    "prod:test": "bun run build && bunx concurrently \"bun run --filter backend start\" \"bun run --filter frontend preview\"",
    "openapi:generate": "bun run --filter backend openapi:generate && bunx openapi-typescript backend/openapi.json -o frontend/src/api/generated/types.ts",
    "openapi:check": "npm run openapi:generate",
    "consistency:check": "bun run lint && bun run openapi:generate && bun run build",
    "typecheck": "bun run --filter '*' typecheck",
    "typecheck-legacy": "bun run --filter '*' typecheck-legacy",
    "lint": "bun run --filter '*' lint",
    "format": "bun run --filter '*' format"
  },
  "keywords": [
    "curling",
    "spare",
    "management"
  ],
  "author": "Triangle Curling Club",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/exporter-logs-otlp-http": "^0.211.0",
    "date-fns": "^4.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.27",
    "drizzle-orm": "^0.44.7",
    "eslint": "^9.39.4"
  }
}
